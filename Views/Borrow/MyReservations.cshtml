@model List<WebProject1.Models.Reservation>
@{
    ViewData["Title"] = "我的预约";
}

<h3 class="mb-3">我的预约</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
        <p class="mt-2">暂无预约记录</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>书名</th>
                    <th>作者</th>
                    <th>分类</th>
                    <th>预约时间</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Book?.Title</td>
                        <td>@r.Book?.Author</td>
                        <td>@r.Book?.Category?.Name</td>
                        <td>@r.ReservedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @switch (r.Status)
                            {
                                case "Pending":
                                    <span class="badge bg-warning text-dark">等待中</span>
                                    break;
                                case "Fulfilled":
                                    <span class="badge bg-success">已完成</span>
                                    break;
                                case "Cancelled":
                                    <span class="badge bg-secondary">已取消</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (r.Status == "Pending")
                            {
                                <form asp-action="CancelReservation" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">取消</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
