@model WebProject1.Models.DashboardViewModel
@{
    ViewData["Title"] = "管理后台";
}

<h3 class="mb-4">管理后台</h3>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card border-0" style="background: #f5f5f7;">
            <div class="card-body text-center py-4">
                <h2 class="fw-bold">@Model.TotalBooks</h2>
                <p class="text-muted mb-0">图书总数</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0" style="background: #f5f5f7;">
            <div class="card-body text-center py-4">
                <h2 class="fw-bold">@Model.TotalUsers</h2>
                <p class="text-muted mb-0">用户总数</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0" style="background: #f5f5f7;">
            <div class="card-body text-center py-4">
                <h2 class="fw-bold">@Model.ActiveBorrows</h2>
                <p class="text-muted mb-0">在借数量</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0" style="background: #f5f5f7;">
            <div class="card-body text-center py-4">
                <h2 class="fw-bold" style="color: var(--apple-red);">@Model.OverdueCount</h2>
                <p class="text-muted mb-0">逾期数量</p>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-5">
    <div class="col-md-3"><a asp-action="Books" class="btn btn-outline-primary w-100">图书管理</a></div>
    <div class="col-md-3"><a asp-action="Categories" class="btn btn-outline-primary w-100">分类管理</a></div>
    <div class="col-md-3"><a asp-action="Users" class="btn btn-outline-primary w-100">用户管理</a></div>
    <div class="col-md-3"><a asp-action="BorrowRecords" class="btn btn-outline-primary w-100">借阅管理</a></div>
</div>

<!-- Recent Borrows -->
<h5 class="fw-semibold mb-3">最近借阅记录</h5>
<div class="card border-0" style="background: #f5f5f7;">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>用户</th>
                    <th>书名</th>
                    <th>借出时间</th>
                    <th>应还时间</th>
                    <th>状态</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.RecentBorrows)
                {
                    <tr>
                        <td>@r.User?.Username</td>
                        <td>@r.BookCopy?.Book?.Title</td>
                        <td>@r.BorrowDate.ToString("yyyy-MM-dd")</td>
                        <td>@r.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (r.Status == "Returned")
                            {
                                <span class="badge bg-success">已归还</span>
                            }
                            else if (r.DueDate < DateTime.Now)
                            {
                                <span class="badge bg-danger">已逾期</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">借阅中</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
