@*
    Admin/BookCopies.cshtml —— 某本书的副本管理页面
    对应 AdminController.BookCopies()
    可以添加新副本、标记副本损坏或恢复可借
*@
@model List<WebProject1.Models.BookCopy>
@{
    @* 从 ViewBag 取出当前管理的图书对象（Controller 中通过 ViewBag.Book 传入） *@
    var book = (WebProject1.Models.Book)ViewBag.Book;
    ViewData["Title"] = $"副本管理 - {book.Title}";
}

<h3 class="mb-3">副本管理 - @book.Title</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@* ========== 添加新副本的表单 ========== *@
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form asp-action="AddCopy" method="post" class="row g-2 align-items-end">
            <input type="hidden" name="bookId" value="@book.Id" />
            <div class="col-md-6">
                <label class="form-label">馆内位置</label>
                <input type="text" name="location" class="form-control" placeholder="如 A区-3排" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">添加副本</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>副本ID</th>
                <th>位置</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var copy in Model)
            {
                <tr>
                    <td>#@copy.Id</td>
                    <td>@(copy.Location ?? "-")</td>
                    <td>
                        @switch (copy.Status)
                        {
                            case "Available":
                                <span class="badge bg-success">可借</span>
                                break;
                            case "Borrowed":
                                <span class="badge bg-primary">已借出</span>
                                break;
                            case "Damaged":
                                <span class="badge bg-danger">损坏</span>
                                break;
                        }
                    </td>
                    <td>
                        @if (copy.Status == "Available")
                        {
                            <form asp-action="UpdateCopyStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@copy.Id" />
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <input type="hidden" name="status" value="Damaged" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">标记损坏</button>
                            </form>
                        }
                        @if (copy.Status == "Damaged")
                        {
                            <form asp-action="UpdateCopyStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@copy.Id" />
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <input type="hidden" name="status" value="Available" />
                                <button type="submit" class="btn btn-sm btn-outline-success">恢复可借</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<a asp-action="Books" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> 返回图书列表</a>
