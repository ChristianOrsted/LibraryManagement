@*
    _ValidationScriptsPartial.cshtml —— 客户端表单验证脚本
    包含 jQuery Validation 和 Unobtrusive Validation 插件
    配合 Model 上的验证特性（如 [Required]、[StringLength]）实现前端实时校验
    在需要表单验证的页面中通过 @section Scripts { <partial name="_ValidationScriptsPartial" /> } 引入
*@
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
