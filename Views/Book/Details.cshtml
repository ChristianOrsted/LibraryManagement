@*
    Book/Details.cshtml —— 图书详情页
    对应 BookController.Details()
    展示单本书的详细信息，并根据用户登录状态和库存情况，显示"借阅"或"预约"按钮
*@
@model WebProject1.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="row mt-3 g-5">
    @* ========== 左侧：封面图片 ========== *@
    <div class="col-md-4">
        <div class="rounded-4 overflow-hidden">
            @if (!string.IsNullOrEmpty(Model.CoverImage))
            {
                <img src="@Model.CoverImage" alt="@Model.Title"
                     class="w-100" style="height: 380px; object-fit: cover; border-radius: 16px;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center"
                     style="height: 380px; background: #e8e8ed; border-radius: 16px;">
                    <span class="fw-bold display-1" style="color: #86868b;">@Model.Title.First()</span>
                </div>
            }
        </div>
    </div>

    @* ========== 右侧：图书信息 + 操作按钮 ========== *@
    <div class="col-md-8">
        <h2 class="fw-bold mb-4" style="letter-spacing: -0.02em;">@Model.Title</h2>

        @* 操作结果提示（借阅成功/失败等） *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @* 图书详细信息表格 *@
        <table class="table table-borderless">
            <tr><th style="width:100px;" class="text-muted fw-medium">作者</th><td>@Model.Author</td></tr>
            <tr><th class="text-muted fw-medium">ISBN</th><td>@(Model.ISBN ?? "N/A")</td></tr>
            <tr><th class="text-muted fw-medium">出版社</th><td>@(Model.Publisher ?? "N/A")</td></tr>
            <tr><th class="text-muted fw-medium">出版年份</th><td>@(Model.PublishYear?.ToString() ?? "N/A")</td></tr>
            <tr><th class="text-muted fw-medium">分类</th><td><span class="badge bg-info">@Model.Category?.Name</span></td></tr>
            <tr>
                <th class="text-muted fw-medium">馆藏状态</th>
                <td>
                    <span class="badge bg-secondary">总计 @ViewBag.TotalCopies 册</span>
                    <span class="badge @(ViewBag.AvailableCopies > 0 ? "bg-success" : "bg-danger")">
                        可借 @ViewBag.AvailableCopies 册
                    </span>
                </td>
            </tr>
        </table>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <h5 class="fw-semibold mt-4 mb-2">简介</h5>
            <p class="text-muted" style="line-height: 1.7;">@Model.Description</p>
        }

        @* ========== 操作按钮区域：根据登录状态和库存分三种情况 ========== *@
        @if (Context.Session.GetInt32("UserId") != null)
        {
            @* 情况1：已登录 *@
            <div class="mt-4">
                @if ((int)ViewBag.AvailableCopies > 0)
                {
                    @* 有可借副本 → 显示"立即借阅"按钮，POST 到 BorrowController.Borrow *@
                    <form asp-controller="Borrow" asp-action="Borrow" method="post" class="d-inline">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary">立即借阅</button>
                    </form>
                }
                else
                {
                    @* 无可借副本 → 显示预约按钮或"已预约"提示 *@
                    @if (ViewBag.HasActiveReservation != null && (bool)ViewBag.HasActiveReservation)
                    {
                        <button class="btn btn-secondary" disabled>已预约</button>
                    }
                    else
                    {
                        <form asp-controller="Borrow" asp-action="Reserve" method="post" class="d-inline">
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <button type="submit" class="btn btn-warning">预约此书</button>
                        </form>
                    }
                }
            </div>
        }
        else
        {
            @* 情况2：未登录 → 提示用户先登录 *@
            <div class="alert alert-info mt-4">
                <a asp-controller="Account" asp-action="Login">登录</a> 后即可借阅或预约图书
            </div>
        }

        <a asp-action="Index" class="btn btn-outline-secondary mt-3">
            <i class="bi bi-arrow-left"></i> 返回列表
        </a>
    </div>
</div>
