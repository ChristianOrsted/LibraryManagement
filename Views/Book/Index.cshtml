@*
    Book/Index.cshtml —— 图书检索页面
    对应 BookController.Index()
    功能：关键词搜索 + 分类筛选 + 分页展示图书列表
    ViewModel 同时包含"搜索条件"和"搜索结果"
*@
@model WebProject1.Models.BookSearchViewModel
@{
    ViewData["Title"] = "图书检索";
}

<h3 class="mb-4">图书检索</h3>

@* ========== 搜索表单 ========== *@
@* method="get" 表示搜索参数通过 URL 查询字符串传递（如 ?keyword=三体&categoryId=1） *@
@* 这样搜索结果页面的 URL 可以被收藏和分享 *@
<div class="card border-0 mb-4" style="background: #f5f5f7;">
    <div class="card-body p-4">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                @* value="@Model.Keyword" 回填上次的搜索关键词，保持搜索状态 *@
                <input type="text" name="keyword" value="@Model.Keyword" class="form-control"
                       placeholder="搜索书名、作者或ISBN..." />
            </div>
            <div class="col-md-4">
                @* 分类下拉框，选中状态通过 selected 属性保持 *@
                <select name="categoryId" class="form-select">
                    <option value="">全部分类</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">搜索</button>
            </div>
        </form>
    </div>
</div>

@* ========== 搜索结果列表 ========== *@
@if (!Model.Books.Any())
{
    @* 无搜索结果时的空状态提示 *@
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
        <p class="mt-2">暂无符合条件的图书</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var book in Model.Books)
        {
            var available = book.BookCopies.Count(c => c.Status == "Available");
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 book-card border-0">
                    @if (!string.IsNullOrEmpty(book.CoverImage))
                    {
                        <img src="@book.CoverImage" alt="@book.Title"
                             class="card-img-top"
                             style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center"
                             style="height: 200px; background: #e8e8ed;">
                            <div class="text-center">
                                <div class="fw-bold fs-3" style="color: #86868b;">@book.Title.First()</div>
                                <small style="color: #aeaeb2;">@book.Author</small>
                            </div>
                        </div>
                    }
                    <div class="card-body p-3">
                        <h6 class="card-title fw-semibold">@book.Title</h6>
                        <p class="card-text small text-muted mb-1">@book.Author</p>
                        <p class="card-text small text-muted mb-2">@book.Category?.Name</p>
                        <span class="badge @(available > 0 ? "bg-success" : "bg-danger")">
                            @(available > 0 ? $"可借 {available} 册" : "已借完")
                        </span>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-3 pt-0">
                        <a asp-action="Details" asp-route-id="@book.Id"
                           class="btn btn-outline-primary btn-sm w-100">查看详情</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @* ========== 分页导航 ========== *@
    @* Url.Action 生成带有搜索条件的分页链接，确保翻页时保留当前的搜索/筛选状态 *@
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { keyword = Model.Keyword, categoryId = Model.CategoryId, page = i })">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
